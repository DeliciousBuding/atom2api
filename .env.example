# Atom2API Configuration

# Server
PORT=8080
BIND_ADDR=0.0.0.0

# Database (SQLite, persisted via Docker volume)
DB_PATH=/data/atom2api.db

# Admin secret (set here or via first-run bootstrap in /admin/)
ADMIN_SECRET=

# Tokens — comma-separated access_token:refresh_token pairs
# Get these from ~/.atomcode/auth.toml on your local machine
# Example: ATOMCODE_TOKENS=token1:refresh1,token2:refresh2
ATOMCODE_TOKENS=

# Default model
DEFAULT_MODEL=deepseek-v4-flash

# Rate limit (requests per minute, 0 = unlimited)
RATE_LIMIT_RPM=0

# Upstream API (rarely need to change)
# UPSTREAM_URL=https://api-ai.gitcode.com/v1/chat/completions
# UPSTREAM_MODELS_URL=https://api.gitcode.com/api/v5/coding-plan/models
