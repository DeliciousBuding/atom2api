# Atom2API Configuration

# Server
PORT=8080
BIND_ADDR=0.0.0.0

# Database (SQLite)
DB_PATH=data/atom2api.db

# Admin dashboard secret (leave empty for no auth)
ADMIN_SECRET=

# Default model for /v1/models
DEFAULT_MODEL=deepseek-v4-flash

# Rate limit (requests per minute, 0 = unlimited)
RATE_LIMIT_RPM=0

# Upstream API (GitCode CodingPlan)
UPSTREAM_URL=https://api-ai.gitcode.com/v1/chat/completions
UPSTREAM_MODELS_URL=https://api.gitcode.com/api/v5/coding-plan/models

# AtomCode config directory (for auto-importing tokens)
# Default: ~/.atomcode
# ATOMCODE_DIR=~/.atomcode

# Override token (skip DB, use this single token)
# ATOMCODE_API_KEY=your_access_token_here
